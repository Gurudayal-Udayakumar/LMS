# No changes needed — SQLite is used by default (no database server required)
# The database URL is configured in prisma/schema.prisma as file:./dev.db

# JWT Secrets (change these in production)
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production

# Server
PORT=5000
NODE_ENV=development

# Email (optional — leave as-is to skip email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lms.com
ENABLE_EMAIL=false
